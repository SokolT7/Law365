# --- LTBLaw konfiguracija ---

# Neobavezno: postavite ključ za AKTIVNI (Live) AI način rada.
# Bez ključa aplikacija radi u DEMO načinu (analiza temeljena na pravilima).
ANTHROPIC_API_KEY=

# Zadani AI model. Promijenite na claude-sonnet-4-6 za brže/jeftinije odgovore.
LTBLAW_MODEL=claude-opus-4-8

# Naziv klijenta (odvjetničkog društva) prikazan u zaglavlju: "LTBLaw × ..."
LTBLAW_FIRM=Odvjetničko društvo Marić & Jurić
